{
  "name": "starter-template-2026",
  "version": "1.0.0",
  "description": "A template to get going quicker with a node app",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "auth:generate": "npx auth@latest generate --output ./src/prisma/schema.prisma",
    "build": "tsc",
    "seed": "npx prisma db seed",
    "start": "node dist/src/index.js",
    "db": "docker compose exec pg_db psql -U postgres",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "better-auth": "^1.5.4",
    "express": "^5.2.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "dotenv": "^17.3.1",
    "prisma": "^7.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
